---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Islas de React (Componentes con interactividad compleja)
import { InscriptionModal } from '../components/InscriptionModal';
import TicketRecovery from '../components/TicketRecovery';
import ConferenceMujeresSection from '../components/ConferenceMujeresSection.astro';
---

<Layout title="Conferencia de Mujeres 2026">
    <Header />
    
    <main>
        <ConferenceMujeresSection />
        
        {/* Sección de Recuperación de Boletos */}
        <section class="relative">
            <TicketRecovery client:visible />
        </section>
    </main>

    <Footer />
    
    {/* El modal se carga bajo demanda o en load si es crítico para la UX inmediata */}
    {/* <InscriptionModal client:load /> -- Nota: El modal suele ser disparado por estado dentro de ConferenceMujeresSection en este proyecto */}
</Layout>

<style>
    main {
        min-height: 100vh;
    }
</style>
