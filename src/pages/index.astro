---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Islas de React (Componentes con interactividad compleja)
import { InscriptionModal } from '../components/InscriptionModal';
import TicketRecovery from '../components/TicketRecovery';
import ConferenceMujeresSection from '../components/ConferenceMujeresSection.astro';
import FloatingActionButton from '../components/FloatingActionButton';
import midSectionImg from '../assets/mid-section-img.webp';
---

<Layout title="Conferencia de Mujeres 2026">
    <Header />
    
    <main>
        <ConferenceMujeresSection />
        
        {/* Imagen de Transición con Bordes Sutiles */}
        <section class="w-full px-4 md:px-12 pt-0 pb-16">
            <div class="relative overflow-hidden h-[45vh] md:h-[40vh] w-full rounded-2xl md:rounded-[3rem] shadow-2xl border border-black/5">
                <img 
                    src={midSectionImg.src} 
                    alt="Conferencia de Mujeres" 
                    class="absolute inset-0 w-full h-full object-cover"
                />
                <div class="absolute inset-0 bg-black/5 mix-blend-overlay"></div>
            </div>
        </section>
        
        {/* Sección de Recuperación de Boletos */}
        <section class="relative">
            <TicketRecovery client:visible />
        </section>
    </main>

    <Footer />
    
    <FloatingActionButton client:load />
    <InscriptionModal client:load />
</Layout>

<style>
    main {
        min-height: 100vh;
    }
</style>
