---
// src/components/BotanicalBackground.astro

const plants = ["version1.webp", "version2.webp", "version3.webp"];
const parallaxGroups = ["up", "down", "left", "right"];

// Algoritmo refinado: Cuadrícula con Variación Extrema (Filtros CSS)
// Con esto, las 3 imágenes parecerán 50 hojas diferentes.
const backgroundPlants = [];
const totalItems = 24; // 6 filas de 4 columnas para asegurar cobertura total

for (let i = 0; i < totalItems; i++) {
  const plantIndex = i % plants.length;
  const file = plants[plantIndex];
  const group = parallaxGroups[i % parallaxGroups.length];
  const scale = 1.25; 

  backgroundPlants.push({ file, group, scale });
}
---

<!-- Botanical background: Perfectly tiled flexbox grid (Zero Overlap) -->
<div class="fixed inset-0 pointer-events-none select-none z-0 overflow-hidden flex flex-wrap content-start mix-blend-multiply" aria-hidden="true" id="botanical-container">
  
  {backgroundPlants.map((plant, index) => {
    // Las primeras 8 imágenes (2 filas) son críticas para la entrada instantánea
    const isPriority = index < 8;
    return (
      <div class="w-1/2 md:w-1/4 aspect-square overflow-hidden">
        <img 
          src={`/plantas/${plant.file}`} 
          alt="" 
          data-parallax-group={plant.group}
          data-parallax-scale={plant.scale}
          class="w-full h-full object-cover planta-parallax will-change-transform"
          loading={isPriority ? "eager" : "lazy"}
          fetchpriority={isPriority ? "high" : "auto"}
          decoding={isPriority ? "sync" : "async"}
          style={`
            opacity: 0.15;
            transform: scale(1.1); /* Estabilización inicial para evitar salto de JS */
          `}
        />
      </div>
    );
  })}

</div>

<script>
  import simpleParallax from 'simple-parallax-js';

  function initParallax() {
    const plants = document.querySelectorAll('.planta-parallax');
    if (plants.length === 0) return;

    const directions = ['up', 'down', 'left', 'right'];
    
    directions.forEach(direction => {
      const elms = document.querySelectorAll(`[data-parallax-group="${direction}"]`);
      if (elms.length > 0) {
        // @ts-ignore - Ignorando error de validacion de construct signature de typescript
        new simpleParallax(elms, {
          orientation: direction,
          scale: 1.6, 
          delay: 0.6, 
          transition: 'cubic-bezier(0.1, 0, 0, 1)',
          overflow: false // Misión Pro: Mantener movimiento DENTRO de la celda (Zero Overlap)
        });
      }
    });
  }

  document.addEventListener('DOMContentLoaded', () => requestAnimationFrame(initParallax));
  document.addEventListener('astro:page-load', () => requestAnimationFrame(initParallax));
</script>
