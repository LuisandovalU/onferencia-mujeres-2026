<style>
  /* Animación CSS para el carrusel infinito (Marquee) Neo-brutalista */
  .animate-marquee {
    animation: marquee 50s linear infinite;
  }
  
  /* Pausar animación al interactuar */
  .group\/marquee:hover .marquee-track {
    animation-play-state: paused;
  }

  .marquee-track {
    animation: marquee 50s linear infinite;
    will-change: transform;
  }

  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-50% - 1rem)); /* -50% because the track holds two identical sets */
    }
  }
</style>
