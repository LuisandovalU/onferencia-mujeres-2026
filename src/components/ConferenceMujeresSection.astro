---
import ConferenceHero from "./ConferenceHero.astro";
import EncuentrosGrid from "./EncuentrosGrid.astro";
import BraveDetails from "./BraveDetails.astro";
import ValienteDetails from "./ValienteDetails.astro";
import { InscribeteButton } from "./InscribeteButton";
import CommentsMarquee from "./CommentsMarquee";
import seccion1 from "@/assets/Seccion1.webp";
import seccion2 from "@/assets/Seccion2.webp";
import seccion3 from "@/assets/Seccion3.webp";
import avatarAbril from "@/assets/brave-carousel-1.webp";
import avatarItzia from "@/assets/valiente-carousel-2.webp";
---


<div
  data-conferencia-mujeres-section
  class="conferencia-root relative isolate min-h-screen text-black antialiased"
>


  <div class="relative z-10 flex flex-col">

    <div class="px-4 pb-4 pt-3 sm:px-5 sm:pb-6 sm:pt-5 md:px-6 md:pb-8 md:pt-6 lg:px-8 xl:px-10 2xl:px-12">
      <ConferenceHero />
    </div>

    <div class="relative overflow-x-visible">

    <!-- ═══════════════════════════════════════════
         SECCIÓN CENTRAL: El Corazón de la Conferencia
         Diseño Minimalista Premium (Fase 2)
    ════════════════════════════════════════════ -->
    
    <!-- 1. Eyebrow + Declaración Principal -->
    <section id="contenido" class="section-container scroll-mt-4 pt-12 pb-16 md:pb-24">
      <div class="flex items-center justify-center gap-4 mb-8 animate-fade-in">
        <div class="h-px w-8 md:w-16 bg-black/20"></div>
        <p class="font-body text-[0.65rem] md:text-[0.75rem] font-bold uppercase tracking-[0.4em] text-neutral-500 text-center">
          Hay espacios que no se repiten y este es uno de ellos
        </p>
        <div class="h-px w-8 md:w-16 bg-black/20"></div>
      </div>

      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-display font-black text-black leading-[1.05] text-[clamp(2.5rem,6vw,4.5rem)] tracking-tighter">
          Nuestra <span class="italic font-medium text-[#6A8654]">conferencia de mujeres</span> es un evento que sucede solo una vez al año.
        </h2>
      </div>
    </section>

    <!-- 2. Sección Independiente (Hacer una pausa) -->
    <section class="section-container pb-24 md:pb-32 px-6">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center max-w-6xl mx-auto">
        <div class="relative aspect-[4/5] md:aspect-square rounded-[2rem] md:rounded-[2.5rem] overflow-hidden bg-neutral-100 shadow-2xl">
          <img src={seccion1.src} alt="Conferencia de mujeres" class="absolute inset-0 w-full h-full object-cover opacity-100 transition-opacity duration-700" />
          <div class="absolute inset-0 bg-black/5 mix-blend-overlay"></div>
        </div>
        <div class="space-y-6">
          <h3 class="font-display text-[1.85rem] md:text-[3rem] leading-[1.15] text-black font-bold tracking-tight text-center md:text-left">
            Diseñado por y para mujeres que desean <span class="underline decoration-[#B9CF63] decoration-[3px] underline-offset-[8px] italic font-medium">hacer una pausa</span>, y encontrarse con Dios de una manera real.
          </h3>
        </div>
      </div>
    </section>

    <!-- 3. Tema Anual Stack Vertical -->
    <section class="w-full bg-brave-dark-deep py-24 md:py-32 my-10 relative overflow-hidden">
      <!-- Decoración Minimalista -->
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(168,196,128,0.1),transparent_70%)]" aria-hidden="true"></div>
      
      <div class="section-container max-w-4xl mx-auto relative z-10 px-8 md:px-6 space-y-20">
        <!-- 1. Texto Introductorio -->
        <p class="font-body text-[1.2rem] md:text-[1.5rem] leading-[1.7] text-white/90 font-light text-center">
          Cada año tenemos un tema distinto para profundizar en nuestros corazones y este es una invitación a 
          <strong class="text-white font-black tracking-wide">dejar el miedo</strong> y recordar que no caminamos solas, que Dios está presente en cada etapa, sosteniéndonos, guiándonos y dándonos fuerzas.
        </p>

        <!-- 2. Imagen Central (Focal Point) -->
        <div class="relative group">
          <div class="relative overflow-hidden rounded-[2rem] md:rounded-[2.5rem] shadow-[0_30px_60px_rgba(0,0,0,0.4)] aspect-[4/3] md:aspect-[21/9] transition-transform duration-1000 group-hover:scale-[1.01]">
            <img 
              src={seccion2.src} 
              alt="Encuentro con Dios" 
              class="absolute inset-0 w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brave-dark-deep/40 to-transparent"></div>
          </div>
        </div>

        <!-- 3. Versículo y Promesa -->
        <div class="relative max-w-2xl mx-auto">
          <svg class="absolute -top-8 -left-2 md:-left-8 w-10 h-10 md:w-12 md:h-12 text-[#a8c480]/20" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 7.55228 14.017 7V5C14.017 4.44772 14.4647 4 15.017 4H19.017C21.2261 4 23.017 5.79086 23.017 8V15C23.017 18.3137 20.3307 21 17.017 21H14.017ZM1.017 21L1.017 18C1.017 16.8954 1.91243 16 3.017 16H6.017C6.56928 16 7.017 15.5523 7.017 15V9C7.017 8.44772 6.56928 8 6.017 8H2.017C1.46472 8 1.017 7.55228 1.017 7V5C1.017 4.44772 1.46472 4 2.017 4H6.017C8.22614 4 10.017 5.79086 10.017 8V15C10.017 18.3137 7.33072 21 4.017 21H1.017Z"/></svg>
          
          <blockquote class="text-center">
            <p class="font-display italic text-[1.1rem] md:text-[1.6rem] leading-[1.6] text-[#def2c1] mb-8 font-medium px-4 md:px-0">
              “No tengas miedo, que yo estoy contigo; no te desanimes, que yo soy tu Dios. Yo soy quien te da fuerzas, y siempre te ayudaré; siempre te sostendré con mi justiciera mano derecha.”
            </p>
            <footer class="font-body text-[0.7rem] md:text-[0.75rem] font-bold uppercase tracking-[0.4em] text-[#a8c480]">
              — Isaías 41:10
            </footer>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- 4. Sección de Acompañamiento -->
    <section class="section-container pb-24 md:pb-32 px-6">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center max-w-6xl mx-auto">
        <div class="relative aspect-[4/5] md:aspect-square rounded-[2rem] md:rounded-[2.5rem] overflow-hidden bg-neutral-100 shadow-2xl md:order-2">
          <img 
            src={seccion3.src} 
            alt="Acompañamiento" 
            class="absolute inset-0 w-full h-full object-cover" 
          />
          <div class="absolute inset-0 bg-black/5 mix-blend-overlay"></div>
        </div>
        <div class="space-y-8 md:order-1">
          <p class="font-display text-[1.5rem] md:text-[2.25rem] text-black leading-[1.4] text-center md:text-right">
            La conferencia está pensada para <span class="text-[#6A8654] font-medium italic">acompañarte</span> según la etapa en la que estás viviendo. No importa si estás comenzando a construir tu camino o si ya llevas años recorriéndolo… 
          </p>
          <span class="block font-black uppercase tracking-[0.2em] text-lg md:text-2xl text-black text-center md:text-right">
            hay un espacio para ti.
          </span>
        </div>
      </div>
    </section>

    <section id="encuentros" class="w-full scroll-mt-4 py-12 md:py-20">
      <EncuentrosGrid />
    </section>

    <!-- ═══════════════════════════════════════════
         DEFINICIONES Y MAPA (Fase 4)
    ════════════════════════════════════════════ -->

    <section class="section-container pb-20 md:pb-24 mt-10">
      <BraveDetails />
    </section>

    <section class="section-container pb-16 md:pb-24">
      <ValienteDetails />
    </section>

    <!-- ¿Dónde Será? (Jungle Botanical Premium) -->
    <section class="w-full bg-brave-dark-deep py-24 md:py-36 overflow-hidden relative">
      <!-- Gradientes Botánicos Atmosféricos -->
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(168,196,128,0.12),transparent_60%)]" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(185,207,99,0.08),transparent_50%)]" aria-hidden="true"></div>
      
      <!-- SVG Hojas Decorativas -->
      <svg class="pointer-events-none absolute top-0 left-0 w-[280px] md:w-[400px] h-auto text-[#A8C480]/[0.06] -translate-x-1/3 -translate-y-1/4" viewBox="0 0 200 300" fill="currentColor" aria-hidden="true">
        <path d="M100 0 C80 60, 20 80, 0 150 C30 130, 60 140, 100 180 C140 140, 170 130, 200 150 C180 80, 120 60, 100 0Z"/>
        <path d="M80 120 C60 180, 10 200, 0 270 C30 250, 50 260, 80 290 C110 260, 130 250, 160 270 C150 200, 100 180, 80 120Z" opacity="0.5"/>
      </svg>
      <svg class="pointer-events-none absolute bottom-0 right-0 w-[200px] md:w-[320px] h-auto text-[#A8C480]/[0.05] translate-x-1/4 translate-y-1/4 rotate-180" viewBox="0 0 200 300" fill="currentColor" aria-hidden="true">
        <path d="M100 0 C80 60, 20 80, 0 150 C30 130, 60 140, 100 180 C140 140, 170 130, 200 150 C180 80, 120 60, 100 0Z"/>
      </svg>

      <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
        
        <!-- Eyebrow -->
        <div class="flex items-center justify-center gap-4 mb-16 md:mb-20">
          <div class="h-px w-8 md:w-16 bg-[#A8C480]/30"></div>
          <p class="font-body text-[0.6rem] md:text-[0.7rem] font-bold uppercase tracking-[0.4em] text-[#A8C480]/70 text-center">
            El lugar perfecto te espera
          </p>
          <div class="h-px w-8 md:w-16 bg-[#A8C480]/30"></div>
        </div>

        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">
          
          <!-- Lado Izquierdo: Mapa Moderno -->
          <div class="relative group">
            <div class="relative overflow-hidden rounded-[2rem] md:rounded-[2.5rem] shadow-[0_30px_80px_-20px_rgba(0,0,0,0.6)] aspect-[4/3] md:aspect-square bg-neutral-900 ring-1 ring-white/10">
              <iframe 
                src="https://maps.google.com/maps?q=Gran+Sal%C3%B3n+del+Valle&t=&z=16&ie=UTF8&iwloc=&output=embed" 
                class="absolute inset-0 w-full h-full grayscale-[0.3] opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-1000 transform scale-105 group-hover:scale-100"
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
              </iframe>
              <!-- Overlay gradiente sutil -->
              <div class="absolute inset-0 bg-gradient-to-t from-brave-dark-deep/30 via-transparent to-transparent pointer-events-none group-hover:opacity-0 transition-opacity duration-700"></div>
            </div>
            <!-- Indicador de interactividad -->
            <div class="absolute -bottom-3 left-1/2 -translate-x-1/2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-4 py-1.5 flex items-center gap-2 opacity-60 group-hover:opacity-100 transition-opacity">
              <div class="w-1.5 h-1.5 rounded-full bg-[#A8C480] animate-pulse"></div>
              <span class="font-body text-[0.6rem] uppercase tracking-[0.15em] text-white/70 font-semibold">Interactivo</span>
            </div>
          </div>

          <!-- Lado Derecho: Información -->
          <div class="flex flex-col items-center text-center md:items-start md:text-left">
            
            <!-- Eyebrow sutil -->
            <p class="font-body italic text-[#A8C480]/80 text-base md:text-lg mb-3 font-light">
              Donde todo sucede
            </p>
            <h2 class="font-display font-black text-[2.8rem] md:text-[4.5rem] leading-[0.9] text-white tracking-[-0.03em] mb-8">
              Gran<br/>Salón del<br/><span class="text-[#A8C480]">Valle.</span>
            </h2>

            <!-- Tarjeta Glass — Solo Dirección -->
            <div class="w-full max-w-sm mb-10">
              <div class="flex items-start gap-4 bg-white/[0.06] backdrop-blur-sm border border-white/10 rounded-2xl px-6 py-5 transition-all duration-300 hover:bg-white/[0.1]">
                <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-[#A8C480]/15 flex items-center justify-center mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#A8C480]"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                </div>
                <div>
                  <p class="font-body text-[0.6rem] uppercase tracking-[0.2em] text-white/40 font-bold mb-1">Dirección</p>
                  <p class="font-body text-sm text-white/90 font-medium leading-relaxed">Gran Salón del Valle<br/><span class="text-white/50 font-light">Ciudad de México, CDMX</span></p>
                </div>
              </div>
            </div>



            <!-- Frase de cierre -->
            <p class="font-body text-sm md:text-base text-white/40 leading-relaxed max-w-sm font-light italic">
              Un espacio elegido con amor para recibirte. Cada detalle está cuidado para que vivas una experiencia que recuerdes por siempre.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Testimonios / Comentarios (Glassmorphism Marquee) -->
    <CommentsMarquee client:visible />

    <section class="section-container pt-20 pb-8 md:pt-32 md:pb-12">
      <div class="flex items-center justify-center gap-4 mb-8">
        <div class="h-px w-8 md:w-16 bg-black/20"></div>
        <p class="font-body text-[0.65rem] md:text-[0.75rem] font-bold uppercase tracking-[0.4em] text-neutral-500 text-center">
          No te pierdas tu lugar
        </p>
        <div class="h-px w-8 md:w-16 bg-black/20"></div>
      </div>

      <div class="max-w-4xl mx-auto text-center px-6">
        <h2 class="font-display font-black text-black leading-[1.1] text-[clamp(2.2rem,6vw,4rem)] tracking-tighter">
          ¿Lista para <span class="italic font-medium text-[#6A8654]">apartar tu lugar</span>? Te esperamos en Brave y Valiente.
        </h2>
        <p class="mt-8 font-body text-base md:text-lg text-neutral-500 leading-relaxed max-w-2xl mx-auto font-light italic">
          Paga directamente con tarjeta, transferencia u Oxxo. Tu registro no toma más de 2 minutos.
        </p>

      </div>
    </section>


  </div> <!-- /relative z-10 flex flex-col -->

</div>


