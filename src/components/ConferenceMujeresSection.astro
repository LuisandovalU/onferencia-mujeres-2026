---
import ConferenceHero from "./ConferenceHero.astro";
import EncuentrosGrid from "./EncuentrosGrid.astro";
import BraveDetails from "./BraveDetails.astro";
import ValienteDetails from "./ValienteDetails.astro";
import { InscribeteButton } from "./InscribeteButton";
import fotoPausa from "@/assets/valiente-carousel-3.webp";
import avatarAbril from "@/assets/brave-carousel-1.webp";
import avatarItzia from "@/assets/valiente-carousel-2.webp";
---


<div
  data-conferencia-mujeres-section
  class="conferencia-root relative isolate min-h-screen text-black antialiased"
>


  <div class="relative z-10 flex flex-col">

    <div class="px-4 pb-4 pt-3 sm:px-5 sm:pb-6 sm:pt-5 md:px-6 md:pb-8 md:pt-6 lg:px-8 xl:px-10 2xl:px-12">
      <ConferenceHero />
    </div>

    <div class="relative overflow-x-visible">

    <!-- ═══════════════════════════════════════════
         SECCIÓN CENTRAL: El Corazón de la Conferencia
         Diseño Minimalista Premium (Fase 2)
    ════════════════════════════════════════════ -->
    
    <!-- 1. Eyebrow + Declaración Principal -->
    <section id="contenido" class="section-container scroll-mt-4 pt-12 pb-16 md:pb-24">
      <div class="flex items-center justify-center gap-4 mb-8 animate-fade-in">
        <div class="h-px w-8 md:w-16 bg-black/20"></div>
        <p class="font-body text-[0.65rem] md:text-[0.75rem] font-bold uppercase tracking-[0.4em] text-neutral-500 text-center">
          Hay espacios que no se repiten y este es uno de ellos
        </p>
        <div class="h-px w-8 md:w-16 bg-black/20"></div>
      </div>

      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-display font-black text-black leading-[1.05] text-[clamp(2.5rem,6vw,4.5rem)] tracking-tighter">
          Nuestra <span class="italic font-medium text-neutral-400">conferencia de mujeres</span> es un evento que sucede solo una vez al año.
        </h2>
      </div>
    </section>

    <!-- 2. Sección Independiente +40 -->
    <section class="section-container pb-20 md:pb-32">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center max-w-6xl mx-auto">
        <div class="order-2 md:order-1 relative aspect-[4/5] md:aspect-square rounded-[2.5rem] overflow-hidden bg-neutral-100 shadow-2xl">
          <img src={fotoPausa.src} alt="Mujer haciendo una pausa" class="absolute inset-0 w-full h-full object-cover grayscale opacity-90 mix-blend-multiply" />
          <div class="absolute inset-0 bg-black/5 mix-blend-overlay"></div>
        </div>
        <div class="order-1 md:order-2 space-y-6">
          <h3 class="font-display text-[1.75rem] md:text-[3rem] leading-[1.15] text-black font-bold tracking-tight">
            Diseñado por y para mujeres que desean <span class="bg-neutral-100 px-3 py-1 rounded-lg italic font-medium">hacer una pausa</span>, y encontrarse con Dios de una manera real.
          </h3>
        </div>
      </div>
    </section>

    <!-- 3. Tema Anual a Pantalla Completa + Versículo Centrado -->
    <section class="w-full bg-brave-dark-deep py-24 md:py-32 my-10 relative overflow-hidden">
      <!-- Decoración Minimalista -->
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(168,196,128,0.1),transparent_70%)]" aria-hidden="true"></div>
      
      <div class="section-container max-w-4xl mx-auto text-center relative z-10">
        <p class="font-body text-[1.2rem] md:text-[1.65rem] leading-[1.7] text-white/90 mb-20 font-light">
          Cada año tenemos un tema distinto para profundizar en nuestros corazones y este es una invitación a 
          <strong class="text-white font-black tracking-wide">dejar el miedo</strong> y recordar que no caminamos solas, que Dios está presente en cada etapa, sosteniéndonos, guiándonos y dándonos fuerzas.
        </p>

        <!-- Versículo Centrado -->
        <div class="relative max-w-3xl mx-auto">
          <svg class="absolute -top-10 left-1/2 -translate-x-1/2 w-14 h-14 text-[#a8c480]/20" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 7.55228 14.017 7V5C14.017 4.44772 14.4647 4 15.017 4H19.017C21.2261 4 23.017 5.79086 23.017 8V15C23.017 18.3137 20.3307 21 17.017 21H14.017ZM1.017 21L1.017 18C1.017 16.8954 1.91243 16 3.017 16H6.017C6.56928 16 7.017 15.5523 7.017 15V9C7.017 8.44772 6.56928 8 6.017 8H2.017C1.46472 8 1.017 7.55228 1.017 7V5C1.017 4.44772 1.46472 4 2.017 4H6.017C8.22614 4 10.017 5.79086 10.017 8V15C10.017 18.3137 7.33072 21 4.017 21H1.017Z"/></svg>
          
          <blockquote class="pt-6">
            <p class="font-display italic text-[1.25rem] md:text-[1.75rem] leading-[1.5] text-[#def2c1] mb-8 font-medium">
              “No tengas miedo, que yo estoy contigo; no te desanimes, que yo soy tu Dios. Yo soy quien te da fuerzas, y siempre te ayudaré; siempre te sostendré con mi justiciera mano derecha.”
            </p>
            <footer class="font-body text-[0.75rem] font-bold uppercase tracking-[0.4em] text-[#a8c480]">
              — Isaías 41:10
            </footer>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- 4. Sección de Acompañamiento (Acceso Directo) -->
    <section class="section-container py-20 md:py-32 text-center flex flex-col items-center">
      <div class="max-w-4xl mx-auto">
        <p class="font-display text-[1.5rem] md:text-[2.25rem] text-black leading-[1.4]">
          La conferencia está pensada para <span class="text-neutral-400 font-medium italic">acompañarte</span> según la etapa en la que estás viviendo. No importa si estás comenzando a construir tu camino o si ya llevas años recorriéndolo… 
          <span class="block mt-8 font-black uppercase tracking-[0.2em] text-lg md:text-2xl text-black">hay un espacio para ti.</span>
        </p>
      </div>
      
      <!-- Flecha de scroll animada hacia encuentros -->
      <a href="#encuentros" class="mt-16 inline-flex items-center justify-center w-16 h-16 rounded-full border border-black/10 hover:border-black hover:bg-black hover:text-white transition-all duration-300 group shadow-sm hover:shadow-xl">
        <svg class="w-6 h-6 text-black group-hover:text-white transform transition-transform group-hover:translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
      </a>
    </section>

    <section id="encuentros" class="w-full scroll-mt-4 py-12 md:py-20">
      <EncuentrosGrid />
    </section>

    <!-- ═══════════════════════════════════════════
         DEFINICIONES Y MAPA (Fase 4)
    ════════════════════════════════════════════ -->

    <section class="section-container pb-20 md:pb-24 mt-10">
      <BraveDetails />
    </section>

    <section class="section-container pb-16 md:pb-24">
      <ValienteDetails />
    </section>

    <!-- ¿Dónde Será? (Aesthetic Arch Windows Style) -->
    <section class="w-full bg-[#faf9f6] py-24 md:py-32 overflow-hidden relative">
      <!-- Decoración Botánica / Polvo de estrellas fondo -->
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[radial-gradient(ellipse_at_center,rgba(216,153,130,0.05),transparent_60%)] pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-[radial-gradient(ellipse_at_center,rgba(168,196,128,0.05),transparent_60%)] pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-6 md:px-12 grid md:grid-cols-2 gap-16 md:gap-24 items-center">
        
        {/* Lado Izquierdo: Tipografía Elegante */}
        <div class="order-2 md:order-1 flex flex-col items-center text-center md:items-start md:text-left z-10">
          <p class="font-serif italic text-neutral-400 text-xl md:text-2xl mb-4">
            Preparamos un lugar especial para ti
          </p>
          <h2 class="font-display font-medium text-[3.5rem] md:text-[5rem] leading-[0.9] text-neutral-900 tracking-[-0.02em] mb-8">
            Gran<br/>Salón del<br/><span class="text-[#D89982]">Valle.</span>
          </h2>
          <p class="font-body text-lg text-neutral-500 leading-relaxed max-w-md mb-12 font-light">
            Todo está diseñado meticulosamente para crear la mejor atmósfera de encuentro. Te esperamos en nuestra sede principal de la Ciudad de México.
          </p>
          
          <a href="https://maps.app.goo.gl/y2FvV8T4cXVfH7K27" target="_blank" class="group flex items-center gap-4 bg-transparent text-neutral-900 border border-neutral-300 px-8 py-5 rounded-full font-bold uppercase tracking-[0.2em] text-[0.65rem] hover:border-[#D89982] hover:bg-[#D89982] hover:text-white transition-all duration-500 shadow-sm hover:shadow-[0_10px_30px_-10px_rgba(216,153,130,0.5)]">
            <span>Ver ruta en Maps</span>
            <svg class="w-4 h-4 transition-transform duration-500 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
        </div>

        {/* Lado Derecho: Mapa Aesthetic (Arch Window) */}
        <div class="order-1 md:order-2 relative flex justify-center md:justify-end z-10 group">
          {/* Fondo del arco simulando un paspartú o marco en la pared */}
          <div class="relative w-[90%] sm:w-[80%] md:w-[420px] aspect-[1/1.3] md:h-[600px] bg-white p-3 md:p-4 rounded-t-[20rem] rounded-b-[2rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.08)] transform group-hover:-translate-y-2 transition-transform duration-700">
            {/* Contenedor del Iframe con clip de arco idéntico */}
            <div class="w-full h-full relative rounded-t-[20rem] rounded-b-2xl overflow-hidden bg-neutral-100">
              <iframe 
                src="https://maps.google.com/maps?q=Gran+Sal%C3%B3n+del+Valle&t=&z=16&ie=UTF8&iwloc=&output=embed" 
                class="absolute inset-0 w-full h-full grayscale-[0.4] opacity-80 mix-blend-multiply group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-1000 transform scale-110 group-hover:scale-100"
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerPolicy="no-referrer-when-downgrade">
              </iframe>
            </div>

            {/* Decoración: SVG Estrellita Minimalista flotando */}
            <svg class="absolute -top-6 -right-6 w-16 h-16 text-[#A8C480] animate-pulse" viewBox="0 0 100 100" fill="currentColor">
               <path d="M50 0 C55 40, 60 45, 100 50 C60 55, 55 60, 50 100 C45 60, 40 55, 0 50 C40 45, 45 40, 50 0 Z" />
            </svg>
          </div>
        </div>

      </div>
    </section>

    <!-- Testimonios (Neo-brutalist / Positivus Style) -->
    <section class="section-container py-24 md:py-32 bg-white overflow-hidden">
      <div class="text-center mb-20">
         <h2 class="font-display font-black text-[clamp(2.5rem,5vw,4.5rem)] text-black tracking-tighter mb-4">
           Lo que vivimos
         </h2>
         <p class="font-body text-neutral-500 text-xs uppercase tracking-widest font-bold">
           Testimonios de ediciones anteriores
         </p>
      </div>

      <!-- Marquee Wrapper -->
      <div class="relative w-full overflow-hidden flex flex-col group/marquee">
        <!-- Blur Gradients (Móvil no son tan necesarios pero en Desktop se ven limpios) -->
        <div class="absolute left-0 top-0 bottom-0 w-8 md:w-32 bg-gradient-to-r from-white to-transparent z-[30] pointer-events-none"></div>
        <div class="absolute right-0 top-0 bottom-0 w-8 md:w-32 bg-gradient-to-l from-white to-transparent z-[30] pointer-events-none"></div>

        <!-- The track -->
        <div class="marquee-track flex gap-8 w-max px-8 md:px-16 pt-5 pb-16 items-center">
          
          {/* Duplicamos un par de tarjetas con contenido dinámico usando la misma estética brutalista */}
          <div class="w-[320px] md:w-[420px] shrink-0 p-8 pb-10 rounded-[2.5rem] bg-white border-[2.5px] border-black flex flex-col group transition-all duration-300 hover:-translate-y-2 hover:-translate-x-1 shadow-[8px_8px_0px_0px_#000000] hover:shadow-[16px_16px_0px_0px_#a8c480] cursor-pointer whitespace-normal">
            <div class="flex items-start justify-between relative z-20">
              <div class="flex items-center gap-4">
                <div class="relative w-12 h-12 flex items-center justify-center">
                  <svg class="absolute -inset-2 w-[4.5rem] h-[4.5rem] text-[#a8c480] z-0 -translate-x-1.5 -translate-y-1.5 transition-transform duration-700 ease-out group-hover:rotate-90 group-hover:scale-110" viewBox="0 0 100 100" fill="currentColor">
                    <path d="M50 0 Q60 40 100 50 Q60 60 50 100 Q40 60 0 50 Q40 40 50 0 Z" />
                  </svg>
                  <div class="w-10 h-10 rounded-full border-[2px] border-black relative z-10 overflow-hidden bg-neutral-200">
                     <img src="/foto-abril-placeholder.jpg" alt="Sofía" class="w-full h-full object-cover grayscale contrast-125" />
                  </div>
                </div>
                <div class="z-10 mt-1">
                  <p class="font-body font-bold text-[1rem] leading-none text-black">Sofía G.</p>
                  <p class="font-body text-[0.6rem] bg-[#a8c480] px-2 py-0.5 mt-1.5 rounded text-black font-extrabold uppercase tracking-widest inline-block border border-black shadow-[2px_2px_0px_0px_#000000]">Brave</p>
                </div>
              </div>
              <div class="w-8 h-8 rounded-full bg-black flex items-center justify-center text-white font-serif italic text-xl leading-none pt-2 group-hover:bg-[#a8c480] group-hover:text-black group-hover:rotate-12 transition-all duration-300 border-[1.5px] border-transparent group-hover:border-black shrink-0">"</div>
            </div>
            <hr class="border-black/20 my-6 w-full group-hover:border-black/50 transition-colors" />
            <p class="font-body text-[1rem] md:text-[1.05rem] leading-[1.6] text-black font-medium z-10 relative">
               La conferencia del año pasado cambió mi perspectiva por completo. Este año vengo obligatoriamente con dos amigas más para compartirlo.
            </p>
          </div>

          <div class="w-[320px] md:w-[420px] shrink-0 p-8 pb-10 rounded-[2.5rem] bg-white border-[2.5px] border-black flex flex-col group transition-all duration-300 hover:-translate-y-2 hover:-translate-x-1 shadow-[8px_8px_0px_0px_#000000] hover:shadow-[16px_16px_0px_0px_#b9cf63] cursor-pointer whitespace-normal">
            <div class="flex items-start justify-between relative z-20">
              <div class="flex items-center gap-4">
                <div class="relative w-12 h-12 flex items-center justify-center">
                  <svg class="absolute -inset-2 w-[4.5rem] h-[4.5rem] text-[#b9cf63] z-0 -translate-x-1.5 -translate-y-1.5 transition-transform duration-700 ease-out group-hover:-rotate-90 group-hover:scale-110" viewBox="0 0 100 100" fill="currentColor">
                    <path d="M40 0 H60 V40 H100 V60 H60 V100 H40 V60 H0 V40 H40 Z" rx="10" />
                  </svg>
                  <div class="w-10 h-10 rounded-full border-[2px] border-black relative z-10 overflow-hidden bg-neutral-200">
                     <img src="/foto-itzia-placeholder.jpg" alt="María" class="w-full h-full object-cover grayscale contrast-125" />
                  </div>
                </div>
                <div class="z-10 mt-1">
                  <p class="font-body font-bold text-[1rem] leading-none text-black">María Elena</p>
                  <p class="font-body text-[0.6rem] bg-amber-200 px-2 py-0.5 mt-1.5 rounded text-black font-extrabold uppercase tracking-widest inline-block border border-black shadow-[2px_2px_0px_0px_#000000]">Mujeres +40</p>
                </div>
              </div>
              <div class="w-8 h-8 rounded-full bg-black flex items-center justify-center text-white font-serif italic text-xl leading-none pt-2 group-hover:bg-[#b9cf63] group-hover:text-black group-hover:rotate-12 transition-all duration-300 border-[1.5px] border-transparent group-hover:border-black shrink-0">"</div>
            </div>
            <hr class="border-black/20 my-6 w-full group-hover:border-black/50 transition-colors" />
            <p class="font-body text-[1rem] md:text-[1.05rem] leading-[1.6] text-black font-medium z-10 relative">
               Me encantó encontrar un espacio sincero para mujeres en mi misma etapa, salí muy renovada y feliz de saber que no camino sola.
            </p>
          </div>

          <div class="w-[320px] md:w-[420px] shrink-0 p-8 pb-10 rounded-[2.5rem] bg-white border-[2.5px] border-black flex flex-col group transition-all duration-300 hover:-translate-y-2 hover:-translate-x-1 shadow-[8px_8px_0px_0px_#000000] hover:shadow-[16px_16px_0px_0px_#e5a0e5] cursor-pointer whitespace-normal">
            <div class="flex items-start justify-between relative z-20">
              <div class="flex items-center gap-4">
                <div class="relative w-12 h-12 flex items-center justify-center">
                  <svg class="absolute -inset-2 w-[4.5rem] h-[4.5rem] text-[#e5a0e5] z-0 -translate-x-1.5 -translate-y-1.5 transition-transform duration-700 ease-out group-hover:rotate-180 group-hover:scale-110" viewBox="0 0 100 100" fill="currentColor">
                    <circle cx="50" cy="50" r="35" stroke="currentColor" stroke-width="4" fill="none" stroke-dasharray="10 5" />
                  </svg>
                  <div class="w-10 h-10 rounded-full border-[2px] border-black relative z-10 overflow-hidden bg-neutral-200"></div>
                </div>
                <div class="z-10 mt-1">
                  <p class="font-body font-bold text-[1rem] leading-none text-black">Andrea R.</p>
                  <p class="font-body text-[0.6rem] bg-[#f9cdff] px-2 py-0.5 mt-1.5 rounded text-black font-extrabold uppercase tracking-widest inline-block border border-black shadow-[2px_2px_0px_0px_#000000]">Conferencia 2025</p>
                </div>
              </div>
              <div class="w-8 h-8 rounded-full bg-black flex items-center justify-center text-white font-serif italic text-xl leading-none pt-2 group-hover:bg-[#e5a0e5] group-hover:text-black group-hover:rotate-12 transition-all duration-300 border-[1.5px] border-transparent group-hover:border-black shrink-0">"</div>
            </div>
            <hr class="border-black/20 my-6 w-full group-hover:border-black/50 transition-colors" />
            <p class="font-body text-[1rem] md:text-[1.05rem] leading-[1.6] text-black font-medium z-10 relative">
               Dios habló a mi corazón en cada plenaria. La atmósfera de adoración fue increíble e inspiradora de principio a fin.
            </p>
          </div>
          
          <div class="w-[320px] md:w-[420px] shrink-0 p-8 pb-10 rounded-[2.5rem] bg-white border-[2.5px] border-black flex flex-col group transition-all duration-300 hover:-translate-y-2 hover:-translate-x-1 shadow-[8px_8px_0px_0px_#000000] hover:shadow-[16px_16px_0px_0px_#a8c480] cursor-pointer whitespace-normal">
            <div class="flex items-start justify-between relative z-20">
              <div class="flex items-center gap-4">
                <div class="relative w-12 h-12 flex items-center justify-center">
                  <svg class="absolute -inset-2 w-[4.5rem] h-[4.5rem] text-[#a8c480] z-0 -translate-x-1.5 -translate-y-1.5 transition-transform duration-700 ease-out group-hover:rotate-180 group-hover:scale-110" viewBox="0 0 100 100" fill="currentColor">
                    <polygon points="50,15 90,85 10,85" />
                  </svg>
                  <div class="w-10 h-10 rounded-full border-[2px] border-black relative z-10 overflow-hidden bg-neutral-200"></div>
                </div>
                <div class="z-10 mt-1">
                  <p class="font-body font-bold text-[1rem] leading-none text-black">Carmen T.</p>
                  <p class="font-body text-[0.6rem] bg-indigo-200 px-2 py-0.5 mt-1.5 rounded text-black font-extrabold uppercase tracking-widest inline-block border border-black shadow-[2px_2px_0px_0px_#000000]">Primera vez</p>
                </div>
              </div>
              <div class="w-8 h-8 rounded-full bg-black flex items-center justify-center text-white font-serif italic text-xl leading-none pt-2 group-hover:bg-[#a8c480] group-hover:text-black group-hover:rotate-12 transition-all duration-300 border-[1.5px] border-transparent group-hover:border-black shrink-0">"</div>
            </div>
            <hr class="border-black/20 my-6 w-full group-hover:border-black/50 transition-colors" />
            <p class="font-body text-[1rem] md:text-[1.05rem] leading-[1.6] text-black font-medium z-10 relative">
               No sabía qué esperar, pero conecté inmediatamente. Las plenarias resolvieron dudas que llevaba arrastrando años. Totalmente catártico.
            </p>
          </div>

          <div class="w-[320px] md:w-[420px] shrink-0 p-8 pb-10 rounded-[2.5rem] bg-white border-[2.5px] border-black flex flex-col group transition-all duration-300 hover:-translate-y-2 hover:-translate-x-1 shadow-[8px_8px_0px_0px_#000000] hover:shadow-[16px_16px_0px_0px_#ff9562] cursor-pointer whitespace-normal">
            <div class="flex items-start justify-between relative z-20">
              <div class="flex items-center gap-4">
                <div class="relative w-12 h-12 flex items-center justify-center">
                  <svg class="absolute -inset-2 w-[4.5rem] h-[4.5rem] text-[#ff9562] z-0 -translate-x-1.5 -translate-y-1.5 transition-transform duration-700 ease-out group-hover:rotate-180 group-hover:scale-110" viewBox="0 0 100 100" fill="currentColor">
                   <path d="M50 0 C60 0, 65 30, 80 30 C95 30, 100 45, 100 50 C100 60, 70 65, 70 80 C70 95, 55 100, 50 100 C40 100, 35 70, 20 70 C5 70, 0 55, 0 50 C0 40, 30 35, 30 20 C30 5, 45 0, 50 0 Z" />
                  </svg>
                  <div class="w-10 h-10 rounded-full border-[2px] border-black relative z-10 overflow-hidden bg-neutral-200"></div>
                </div>
                <div class="z-10 mt-1">
                  <p class="font-body font-bold text-[1rem] leading-none text-black">Luisa F.</p>
                  <p class="font-body text-[0.6rem] bg-[#ffc3a8] px-2 py-0.5 mt-1.5 rounded text-black font-extrabold uppercase tracking-widest inline-block border border-black shadow-[2px_2px_0px_0px_#000000]">Valiente</p>
                </div>
              </div>
              <div class="w-8 h-8 rounded-full bg-black flex items-center justify-center text-white font-serif italic text-xl leading-none pt-2 group-hover:bg-[#ff9562] group-hover:text-black group-hover:rotate-12 transition-all duration-300 border-[1.5px] border-transparent group-hover:border-black shrink-0">"</div>
            </div>
            <hr class="border-black/20 my-6 w-full group-hover:border-black/50 transition-colors" />
            <p class="font-body text-[1rem] md:text-[1.05rem] leading-[1.6] text-black font-medium z-10 relative">
               Como mamá de 3, es difícil darme un tiempo para mí. Estos dos días fueron un tanque de oxígeno puro para mi vida e identidad de vuelta.
            </p>
          </div>
          
