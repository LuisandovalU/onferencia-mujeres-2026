---
import ConferenceHero from "./ConferenceHero.astro";
import EncuentrosGrid from "./EncuentrosGrid.astro";
import BraveDetails from "./BraveDetails.astro";
import ValienteDetails from "./ValienteDetails.astro";
import { InscribeteButton } from "./InscribeteButton";
---


<div
  data-conferencia-mujeres-section
  class="conferencia-root relative isolate min-h-screen text-black antialiased"
>


  <div class="relative z-10 flex flex-col">

    <div class="px-4 pb-4 pt-3 sm:px-5 sm:pb-6 sm:pt-5 md:px-6 md:pb-8 md:pt-6 lg:px-8 xl:px-10 2xl:px-12">
      <ConferenceHero />
    </div>

    <div class="relative overflow-x-visible">

    <!-- ═══════════════════════════════════════════
         SECCIÓN CENTRAL: El Corazón de la Conferencia
         Diseño Rediseñado (Abril 2026)
    ════════════════════════════════════════════ -->
    <section id="contenido" class="section-container scroll-mt-4 pb-12 pt-10 md:pb-16 md:pt-12">
      <!-- Card único con diseño premium -->
      <div class="relative rounded-[3.5rem] overflow-hidden bg-brave-dark-deep shadow-2xl border border-white/5">
        
        <!-- Capas de iluminación dinámica -->
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_30%,rgba(74,110,58,0.15),transparent_70%)]" aria-hidden="true"></div>
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_80%_80%,rgba(30,51,25,0.4),transparent_60%)]" aria-hidden="true"></div>

        <!-- 🌿 Fondo botánico sutil -->
        <img
          src="/fondo.webp"
          alt=""
          aria-hidden="true"
          class="pointer-events-none select-none absolute inset-0 w-full h-full object-cover opacity-[0.06] grayscale z-0"
        />

        <div class="relative z-10 px-8 py-16 md:px-20 md:py-24 max-w-5xl mx-auto">
          
          <!-- Eyebrow con resalto -->
          <div class="flex items-center gap-4 mb-10 animate-fade-in">
            <div class="h-px w-8 bg-[#a8c480]/40"></div>
            <p class="font-body text-[0.65rem] md:text-[0.7rem] font-black uppercase tracking-[0.4em] text-[#a8c480]">
              Hay espacios que no se repiten y este es uno de ellos
            </p>
          </div>

          <!-- Declaración Principal -->
          <div class="space-y-8 mb-16">
            <h2 class="font-display font-black text-white leading-[1.1] text-[clamp(1.75rem,5vw,3.8rem)] tracking-tighter">
              Nuestra <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#a8c480] via-[#def2c1] to-[#a8c480]">conferencia de mujeres</span> es un evento que sucede solo una vez al año.
            </h2>
            <p class="font-body text-[1.1rem] md:text-[1.35rem] leading-[1.6] text-white/80 font-medium max-w-3xl">
              Diseñado por y para mujeres que desean <span class="text-white border-b-2 border-[#a8c480]/30 italic">hacer una pausa</span>, y encontrarse con Dios de una manera real.
            </p>
          </div>

          <!-- Bloque de Profundización -->
          <div class="grid md:grid-cols-2 gap-12 items-start mb-20">
            <p class="font-body text-[0.95rem] md:text-[1.05rem] leading-[1.8] text-white/70">
              Cada año tenemos un tema distinto para profundizar en nuestros corazones y este es una invitación a 
              <strong class="text-white">dejar el miedo</strong> y recordar que no caminamos solas, que Dios está presente en cada etapa, sosteniéndonos, guiándonos y dándonos fuerzas.
            </p>
            
            <!-- Versículo Bíblico: Diseño de Resalto -->
            <div class="relative p-8 md:p-10 rounded-[2.5rem] bg-white/[0.03] backdrop-blur-sm border border-white/10 shadow-inner overflow-hidden group">
              <div class="absolute -right-10 -top-10 w-32 h-32 bg-[#a8c480]/10 rounded-full blur-3xl transition-all group-hover:bg-[#a8c480]/20"></div>
              
              <svg class="absolute top-6 left-6 w-10 h-10 text-[#a8c480]/20" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 7.55228 14.017 7V5C14.017 4.44772 14.4647 4 15.017 4H19.017C21.2261 4 23.017 5.79086 23.017 8V15C23.017 18.3137 20.3307 21 17.017 21H14.017ZM1.017 21L1.017 18C1.017 16.8954 1.91243 16 3.017 16H6.017C6.56928 16 7.017 15.5523 7.017 15V9C7.017 8.44772 6.56928 8 6.017 8H2.017C1.46472 8 1.017 7.55228 1.017 7V5C1.017 4.44772 1.46472 4 2.017 4H6.017C8.22614 4 10.017 5.79086 10.017 8V15C10.017 18.3137 7.33072 21 4.017 21H1.017Z"/></svg>

              <blockquote class="relative z-10">
                <p class="font-display italic text-[1.15rem] md:text-[1.25rem] leading-[1.7] text-[#def2c1] mb-6 pt-4">
                  “No tengas miedo, que yo estoy contigo; no te desanimes, que yo soy tu Dios. Yo soy quien te da fuerzas, y siempre te ayudaré; siempre te sostendré con mi justiciera mano derecha.”
                </p>
                <footer class="font-body text-[0.65rem] font-bold uppercase tracking-[0.3em] text-[#a8c480]/60">
                  — Isaías 41:10
                </footer>
              </blockquote>
            </div>
          </div>

          <!-- Cierre / Invitación Contextual -->
          <div class="pt-10 border-t border-white/10">
            <p class="font-display text-[1.2rem] md:text-[1.5rem] text-white leading-relaxed max-w-2xl">
              La conferencia está pensada para <span class="text-[#a8c480] font-bold italic">acompañarte</span> según la etapa en la que estás viviendo. No importa si estás comenzando a construir tu camino o si ya llevas años recorriéndolo… 
              <span class="block mt-4 text-transparent bg-clip-text bg-gradient-to-r from-white to-white/40 font-black uppercase tracking-widest text-sm md:text-base">hay un espacio para ti.</span>
            </p>
          </div>

        </div>  <!-- /relative z-10 px -->
      </div>  <!-- /card premium -->
    </section>

    <section id="encuentros" class="section-container scroll-mt-4 py-12 md:py-20">
      <EncuentrosGrid />
    </section>

    <section class="section-container pb-20 md:pb-28">
      <BraveDetails />
    </section>

    <section class="section-container pb-16 md:pb-24">
      <ValienteDetails />
    </section>

    <section class="section-container pb-20 md:pb-28">
      <div class="relative overflow-hidden rounded-[2rem] bg-brave-dark-deep px-6 py-12 text-center shadow-xl md:px-12 md:py-16">
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-20%,rgba(255,255,255,0.12),transparent_55%)]"
          aria-hidden="true"
        ></div>
        <div
          class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-white/5 blur-3xl"
          aria-hidden="true"
        ></div>
        <div
          class="pointer-events-none absolute -bottom-16 -left-10 h-40 w-40 rounded-full bg-forest/40 blur-2xl"
          aria-hidden="true"
        ></div>
        <p class="font-body text-label font-semibold uppercase tracking-[0.28em] text-white/70">
          No te pierdas tu lugar
        </p>
        <h2 class="mt-4 font-display text-[clamp(1.5rem,4vw,2.75rem)] font-extrabold leading-tight tracking-tight text-white">
          ¿Lista para apartar tu lugar?
        </h2>
        <p class="mx-auto mt-4 max-w-xl font-body text-base leading-relaxed text-white/90 sm:text-lg">
          Completa tu inscripción y recibe los datos de transferencia. Te esperamos en Brave y Valiente.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-6 relative z-50">
          <InscribeteButton 
            client:load 
            variant="light"
            className="px-5 py-2.5 sm:px-10 sm:py-4 border-2 border-neutral-900 shadow-[0_0_40px_-12px_rgba(255,255,255,0.4)] ring-4 ring-white/20 font-bold"
          />
        </div>
      </div>
    </section>

  </div> <!-- /relative z-10 flex flex-col -->

</div>
