---
import { InscribeteButton } from "./InscribeteButton";
import { AutoImageCarousel } from "./AutoImageCarousel";

import braveTextLogo from "@/assets/brave.webp";
import braveContentPhoto from "@/assets/Brave-1.webp";
import queesBraveBanner from "@/assets/qb_photo.webp";
import queesBraveLogo from "@/assets/queesbrave.webp";

const BRAVE_BANNER_SLIDES = [
  { src: queesBraveBanner, alt: "Conferencia Brave" },
];

const BRAVE_CONTENT_SRC = braveContentPhoto.src;
const BRAVE_TEXT_LOGO_SRC = braveTextLogo.src;
const QUEES_BRAVE_LOGO_SRC = queesBraveLogo.src;

const copy = {
  date: "24 de mayo • 5:00 pm",
  location: "Gran Salón del Valle",
  body: "¿Qué es Brave?",
};
---

<div 
  class="overflow-hidden rounded-[2rem] bg-brave-dark-deep cursor-pointer group transition-all duration-500 hover:ring-2 hover:ring-white/20 shadow-2xl"
  onclick="document.getElementById('brave-details-modal').showModal()"
>
  <div class="grid gap-0 md:grid-cols-2">
    <div class="relative aspect-[4/3] min-h-[240px] md:aspect-auto md:min-h-[420px]">
      <AutoImageCarousel
        slides={BRAVE_BANNER_SLIDES}
        intervalMs={2000}
        className="absolute inset-0"
        sizes="(max-width: 768px) 100vw, 50vw"
        priorityFirst={true}
        client:visible
      />
    </div>
    <div class="flex flex-col justify-center p-8 text-white md:p-12 lg:p-14">
      <p class="font-body text-label font-semibold uppercase tracking-[0.28em] text-white/60 text-center md:text-left mb-4">
        {copy.date}
      </p>
      
      <button 
        onclick="document.getElementById('brave-details-modal').showModal()"
        class="group relative inline-flex items-center justify-center md:justify-start outline-none transition-all"
        aria-label="Descubre qué es Brave"
      >
        <img 
          src={QUEES_BRAVE_LOGO_SRC} 
          alt="¿Qué es Brave?" 
          class="h-[70px] md:h-[100px] w-auto brightness-0 invert opacity-[0.85] transition-transform duration-300 group-hover:scale-[1.05]" 
        />
        <span class="absolute -bottom-1 left-0 h-[3px] rounded-full w-0 bg-white/40 transition-all duration-300 group-hover:w-[90%] md:group-hover:w-[80%]"></span>
      </button>

      <p class="font-body text-base md:text-lg leading-[1.6] text-white/90 max-w-md mt-6">
        Si estás formando tu identidad y tu dirección, este espacio es para ti.
      </p>
      <span class="font-body text-[0.65rem] md:text-xs font-extrabold tracking-[0.2em] uppercase text-[#a8c480] mt-4">
        UNIVERSITARIAS • EMPRENDEDORAS • PROFESIONALES
      </span>
    </div>
  </div>
</div>

<!-- Pequeña ventana emergente muy detallada y femenina -->
<dialog id="brave-details-modal" class="backdrop:backdrop-blur-md backdrop:bg-black/60 rounded-[2.5rem] bg-brave-dark-deep border border-white/10 shadow-2xl max-w-lg w-[92vw] overflow-hidden text-white m-auto fixed inset-0 z-[100]">
  <div class="relative p-7 md:p-14 flex flex-col items-center overflow-y-auto max-h-[90vh]">
    <!-- Close Button -->
    <button 
      onclick="document.getElementById('brave-details-modal').close(); event.stopPropagation();" 
      class="absolute top-6 right-6 text-white/30 hover:text-white hover:bg-white/10 p-2.5 rounded-full transition-all outline-none border border-transparent hover:border-white/10"
      aria-label="Cerrar detalles"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    
    <!-- Logo & Divider -->
    <div class="mb-10 mt-4 flex flex-col items-center">
      <img src={BRAVE_TEXT_LOGO_SRC} alt="Brave" class="h-9 md:h-12 w-auto brightness-0 invert opacity-90" />
      <div class="h-1 w-12 bg-[#a8c480] rounded-full mt-4 opacity-50"></div>
    </div>
    
    <div class="space-y-8 text-center md:text-left w-full">
      <h3 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-white leading-tight">
        Un espacio para mujeres que están <span class="italic font-medium text-[#a8c480]">construyendo</span> su camino.
      </h3>
      
      <div class="space-y-6">
        <p class="font-body text-base md:text-lg leading-relaxed text-white/70 font-light">
          Entre la universidad, el inicio de la vida profesional, presión, relaciones, sueños, decisiones y cambios constantes, nacen muchas preguntas.
        </p>

        <p class="font-body text-base md:text-lg leading-relaxed text-white/90 font-medium">
          <span class="text-[#a8c480] font-black uppercase tracking-widest text-sm mr-2">Brave</span> 
          es un encuentro para hablar de la valentía que se necesita para enfrentar esta etapa y escuchar la voz de Dios en medio del ruido.
        </p>
      </div>

      <div class="py-6 px-8 rounded-3xl bg-white/5 border border-white/10 relative overflow-hidden">
        <div class="absolute -left-1 top-0 bottom-0 w-1.5 bg-[#a8c480]/40 rounded-full"></div>
        <p class="font-body text-base md:text-lg leading-relaxed text-[#def2c1] italic font-medium">
          "Si estás formando tu identidad y tu dirección, este espacio es para ti."
        </p>
      </div>
    </div>

    <!-- Logistics Section -->
    <div class="mt-12 w-full grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="p-5 rounded-2xl bg-white/[0.03] border border-white/5 flex flex-col gap-2 items-center md:items-start text-center md:text-left">
        <span class="text-[0.6rem] font-black uppercase tracking-[0.3em] text-white/40">Cuándo</span>
        <div class="flex items-center gap-3 text-white/90 font-body text-xs font-bold uppercase tracking-wider">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#a8c480]"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          <span>24 Mayo • 5:00 PM</span>
        </div>
      </div>
      <div class="p-5 rounded-2xl bg-white/[0.03] border border-white/5 flex flex-col gap-2 items-center md:items-start text-center md:text-left">
        <span class="text-[0.6rem] font-black uppercase tracking-[0.3em] text-white/40">Dónde</span>
        <div class="flex items-center gap-3 text-white/90 font-body text-xs font-bold uppercase tracking-wider">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#a8c480]"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          <span>Gran Salón del Valle</span>
        </div>
      </div>
    </div>

    <div class="mt-10 mb-2 w-full">
      <InscribeteButton 
        client:load 
        conferencia="brave" 
        variant="light"
        className="w-full py-5 text-base font-black uppercase tracking-widest shadow-2xl shadow-black/40 hover:scale-[1.02] active:scale-95 transition-all"
      >
        Inscribirme ahora
      </InscribeteButton>
      <p class="text-center mt-6 text-[0.65rem] font-bold uppercase tracking-[0.2em] text-white/20">Cupo limitado por sesión</p>
    </div>
  </div>
</dialog>

<style>
  dialog[open] {
    animation: scale-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  dialog::backdrop {
    animation: fade-in 0.5s ease-out forwards;
  }
  @keyframes scale-up {
    0% { opacity: 0; transform: scale(0.9) translateY(15px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
  @keyframes fade-in {
    0% { opacity: 0; backdrop-filter: blur(0px); background: rgba(0, 0, 0, 0); }
    100% { opacity: 1; backdrop-filter: blur(8px); background: rgba(0, 0, 0, 0.5); }
  }
</style>
