---
import { InscribeteButton } from "./InscribeteButton";
import { AutoImageCarousel } from "./AutoImageCarousel";
import valienteTextLogo from "@/assets/valiente.webp";
import valienteContentPhoto from "@/assets/Val-1.webp";
import queesValienteBanner from "@/assets/qv_photo.webp";
import queesValienteLogo from "@/assets/queesvaliente.webp";

const VALIENTE_BANNER_SLIDES = [
  { src: queesValienteBanner, alt: "Conferencia Valiente" },
];

const VALIENTE_CONTENT_SRC = valienteContentPhoto.src;
const VALIENTE_TEXT_LOGO_SRC = valienteTextLogo.src;
const QUEES_VALIENTE_LOGO_SRC = queesValienteLogo.src;

const copy = {
  date: "31 de mayo • 3:00 pm",
  location: "Gran Salón del Valle",
  body: "¿Qué es Valiente?",
};
---

<div 
  class="overflow-hidden rounded-[2rem] bg-valiente-beige shadow-card cursor-pointer group transition-all duration-500 hover:ring-2 hover:ring-valiente-dark/10"
  onclick="document.getElementById('valiente-details-modal').showModal()"
>
  <div class="grid gap-0 md:grid-cols-2">
    <div class="order-2 flex flex-col justify-center p-8 md:order-1 md:p-12 lg:p-14">
      <p class="font-body text-label font-semibold uppercase tracking-[0.28em] text-valiente-dark/50 text-center md:text-left mb-4">
        {copy.date}
      </p>

      <button 
        onclick="document.getElementById('valiente-details-modal').showModal()"
        class="group relative inline-flex items-center justify-center md:justify-start outline-none transition-all"
        aria-label="Descubre qué es Valiente"
      >
        <img 
          src={QUEES_VALIENTE_LOGO_SRC} 
          alt="¿Qué es Valiente?" 
          class="h-[70px] md:h-[100px] w-auto opacity-[0.95] transition-transform duration-300 group-hover:scale-[1.05]" 
        />
        <span class="absolute -bottom-1 left-0 h-[3px] rounded-full w-0 bg-valiente-dark/20 transition-all duration-300 group-hover:w-[90%] md:group-hover:w-[80%]"></span>
      </button>

      <!-- Bajada Textual Estática -->
      <div class="mt-8 flex flex-col text-center md:text-left gap-3">
        <p class="font-body text-base md:text-lg leading-[1.6] text-valiente-dark/90 max-w-md">
          Si sabes que aún hay más que Dios quiere hacer en ti, este espacio es para ti.
        </p>
        <span class="font-body text-[0.65rem] md:text-xs font-extrabold tracking-[0.2em] uppercase text-valiente-dark/60">
          MADRES • CASADAS • MUJERES +40
        </span>
      </div>
    </div>
    <div class="relative order-1 aspect-[4/3] min-h-[240px] md:order-2 md:aspect-auto md:min-h-[420px]">
      <AutoImageCarousel
        slides={VALIENTE_BANNER_SLIDES}
        intervalMs={2000}
        className="absolute inset-0"
        sizes="(max-width: 768px) 100vw, 50vw"
        client:visible
      />
    </div>
  </div>
</div>

<!-- Pequeña ventana emergente muy detallada y femenina -->
<dialog id="valiente-details-modal" class="backdrop:backdrop-blur-md backdrop:bg-black/60 rounded-[2.5rem] bg-valiente-beige border border-valiente-dark/10 shadow-2xl max-w-lg w-[92vw] overflow-hidden text-valiente-dark m-auto fixed inset-0 z-[100]">
  <div class="relative p-7 md:p-14 flex flex-col items-center overflow-y-auto max-h-[90vh]">
    <!-- Close Button -->
    <button 
      onclick="document.getElementById('valiente-details-modal').close(); event.stopPropagation();" 
      class="absolute top-6 right-6 text-valiente-dark/30 hover:text-valiente-dark hover:bg-valiente-dark/5 p-2.5 rounded-full transition-all outline-none border border-transparent hover:border-valiente-dark/10"
      aria-label="Cerrar detalles"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    
    <!-- Logo & Divider -->
    <div class="mb-10 mt-4 flex flex-col items-center">
      <img src={VALIENTE_TEXT_LOGO_SRC} alt="Valiente" class="h-9 md:h-12 w-auto opacity-90" />
      <div class="h-1 w-12 bg-valiente-dark/20 rounded-full mt-4"></div>
    </div>
    
    <div class="space-y-8 text-center md:text-left w-full">
      <h3 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-valiente-dark leading-tight">
        Un espacio para mujeres que ya han <span class="italic font-medium text-valiente-dark/70">recorrido</span> camino.
      </h3>
      
      <div class="space-y-6">
        <p class="font-body text-base md:text-lg leading-relaxed text-valiente-dark/70 font-light">
          Entre hijos, familia, trabajo y responsabilidades, la vida toma otro ritmo… y con él, nuevos retos y preguntas más profundas.
        </p>

        <p class="font-body text-base md:text-lg leading-relaxed text-valiente-dark/90 font-medium">
          <span class="text-valiente-dark font-black uppercase tracking-widest text-sm mr-2">Valiente</span> 
          es un encuentro para reconectar con esa fuerza interior que no nace de la experiencia, sino de una relación real con Dios.
        </p>
      </div>

      <div class="py-6 px-8 rounded-3xl bg-black/[0.03] border border-black/5 relative overflow-hidden">
        <div class="absolute -left-1 top-0 bottom-0 w-1.5 bg-valiente-dark/20 rounded-full"></div>
        <p class="font-body text-base md:text-lg leading-relaxed text-valiente-dark/80 italic font-medium">
          "La valentía para sostener, soltar, sanar y seguir avanzando con fe."
        </p>
      </div>
    </div>

    <!-- Logistics Section -->
    <div class="mt-12 w-full grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="p-5 rounded-2xl bg-black/[0.02] border border-black/5 flex flex-col gap-2 items-center md:items-start text-center md:text-left">
        <span class="text-[0.6rem] font-black uppercase tracking-[0.3em] text-valiente-dark/40">Cuándo</span>
        <div class="flex items-center gap-3 text-valiente-dark/90 font-body text-xs font-bold uppercase tracking-wider">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-valiente-dark/40"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          <span>31 Mayo • 3:00 PM</span>
        </div>
      </div>
      <div class="p-5 rounded-2xl bg-black/[0.02] border border-black/5 flex flex-col gap-2 items-center md:items-start text-center md:text-left">
        <span class="text-[0.6rem] font-black uppercase tracking-[0.3em] text-valiente-dark/40">Dónde</span>
        <div class="flex items-center gap-3 text-valiente-dark/90 font-body text-xs font-bold uppercase tracking-wider">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-valiente-dark/40"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          <span>Gran Salón del Valle</span>
        </div>
      </div>
    </div>

    <div class="mt-10 mb-2 w-full">
      <InscribeteButton 
        client:load 
        conferencia="valiente" 
        variant="dark"
        className="w-full py-5 text-base font-black uppercase tracking-widest shadow-2xl shadow-black/10 hover:scale-[1.02] active:scale-95 transition-all"
      >
        Inscribirme ahora
      </InscribeteButton>
      <p class="text-center mt-6 text-[0.65rem] font-bold uppercase tracking-[0.2em] text-valiente-dark/20">Cupo limitado por sesión</p>
    </div>
  </div>
</dialog>

<style>
  dialog[open] {
    animation: scale-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  dialog::backdrop {
    animation: fade-in 0.5s ease-out forwards;
  }
  @keyframes scale-up {
    0% { opacity: 0; transform: scale(0.9) translateY(15px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
  @keyframes fade-in {
    0% { opacity: 0; backdrop-filter: blur(0px); background: rgba(0, 0, 0, 0); }
    100% { opacity: 1; backdrop-filter: blur(8px); background: rgba(0, 0, 0, 0.5); }
  }
</style>
