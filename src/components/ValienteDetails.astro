---
import { InscribeteButton } from "./InscribeteButton";
import { AutoImageCarousel } from "./AutoImageCarousel";
import valienteText from "@/assets/valiente.webp";
import valienteCarousel1 from "@/assets/valiente-carousel-1.webp";
import valienteCarousel2 from "@/assets/valiente-carousel-2.webp";
import valienteCarousel3 from "@/assets/valiente-carousel-3.webp";

const VALIENTE_SLIDES = [
  { src: valienteCarousel1, alt: "Conferencia Valiente — comunidad y adoración" },
  { src: valienteCarousel2, alt: "Conferencia Valiente — encuentro al aire libre" },
  { src: valienteCarousel3, alt: "Conferencia Valiente — momento" },
];

const VALIENTE_TEXT_SRC = valienteText.src;

const copy = {
  date: "31 de mayo • 3:00 pm",
  location: "Gran Salón del Valle",
  body: "¿Qué es Valiente?",
};
---

<div 
  class="overflow-hidden rounded-[2rem] bg-valiente-beige shadow-card cursor-pointer group transition-all duration-500 hover:ring-2 hover:ring-valiente-dark/10"
  onclick="document.getElementById('valiente-details-modal').showModal()"
>
  <div class="grid gap-0 md:grid-cols-2">
    <div class="order-2 flex flex-col justify-center p-8 md:order-1 md:p-12 lg:p-14">
      <p class="font-body text-label font-semibold uppercase tracking-[0.28em] text-valiente-dark/50 text-center md:text-left mb-4">
        {copy.date}
      </p>

      <button 
        onclick="document.getElementById('valiente-details-modal').showModal()"
        class="group relative inline-flex items-center justify-center md:justify-start outline-none transition-all"
        aria-label="Descubre qué es Valiente"
      >
        <p class="font-display text-[clamp(2.5rem,4vw,3.5rem)] font-extrabold tracking-tight text-valiente-dark text-center md:text-left leading-tight flex items-center transition-transform duration-300 group-hover:scale-[1.02] group-active:scale-[0.98] cursor-pointer">
          ¿Qué es <img src={VALIENTE_TEXT_SRC} alt="Valiente" class="inline-block h-[0.75em] w-auto mx-2 -translate-y-1 object-contain" />?
        </p>
        <span class="absolute -bottom-1 left-0 h-[3px] rounded-full w-0 bg-valiente-dark/20 transition-all duration-300 group-hover:w-[90%] md:group-hover:w-[80%]"></span>
      </button>

    </div>
    <div class="relative order-1 aspect-[4/3] min-h-[240px] md:order-2 md:aspect-auto md:min-h-[420px]">
      <AutoImageCarousel
        slides={VALIENTE_SLIDES}
        intervalMs={2000}
        className="absolute inset-0"
        sizes="(max-width: 768px) 100vw, 50vw"
        client:visible
      />
    </div>
  </div>
</div>

<!-- Pequeña ventana emergente muy detallada y femenina -->
<dialog id="valiente-details-modal" class="backdrop:backdrop-blur-md backdrop:bg-black/50 rounded-[2.5rem] bg-valiente-beige border border-valiente-dark/10 shadow-[0_25px_50px_-12px_rgba(0,0,0,0.4)] max-w-md w-[90vw] overflow-hidden text-valiente-dark m-auto fixed inset-0 z-50">
  <div class="relative p-8 md:p-12 flex flex-col items-start overflow-y-auto max-h-[90vh]">
    <button onclick="document.getElementById('valiente-details-modal').close(); event.stopPropagation();" class="absolute top-5 right-5 text-valiente-dark/30 hover:text-valiente-dark hover:bg-valiente-dark/5 p-2 rounded-full transition-all outline-none" aria-label="Cerrar detalles">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    
    <img src={VALIENTE_TEXT_SRC} alt="Valiente" class="h-10 mb-8 opacity-[0.95] self-center" />
    
    <div class="space-y-6 text-left w-full">
      <p class="font-body text-[1.1rem] leading-[1.6] text-valiente-dark/90">
        Un espacio para mujeres que ya han recorrido camino.
      </p>
      
      <p class="font-body text-[1rem] leading-[1.6] text-valiente-dark/70">
        Entre hijos, familia, trabajo y responsabilidades, la vida toma otro ritmo… y con él, nuevos retos y preguntas más profundas.
      </p>

      <p class="font-body text-[1rem] leading-[1.6] text-valiente-dark/90">
        <strong class="text-valiente-dark">Valiente</strong> es un encuentro para recolectar con esa fuerza interior que no nace de la experiencia, sino de una relación real con Dios.
      </p>

      <p class="font-body text-[1rem] leading-[1.6] text-valiente-dark/80 italic border-l-2 border-valiente-dark/20 pl-4">
        La valentía para sostener, soltar, sanar y seguir avanzando con fe.
      </p>

      <p class="font-body text-[1rem] leading-[1.6] text-valiente-dark/90">
        Si sabes que aún hay más que Dios quiere hacer en ti, este espacio es para ti.
      </p>
    </div>

    <!-- Sección de Logística con diseño de tarjeta -->
    <div class="mt-10 w-full p-6 rounded-2xl bg-black/5 border border-black/10 flex flex-col gap-3">
      <div class="flex items-center gap-3 text-valiente-dark/60 font-body text-[0.7rem] uppercase tracking-[0.2em] font-black">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-valiente-dark/40"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        <span>Cuándo: 31 de mayo • 3:00 PM</span>
      </div>
      <div class="flex items-center gap-3 text-valiente-dark/60 font-body text-[0.7rem] uppercase tracking-[0.2em] font-black">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-valiente-dark/40"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        <span>Dónde: Gran Salón del Valle</span>
      </div>
    </div>

    <div className="mt-8 mb-2 w-full flex flex-col gap-4">
      <InscribeteButton 
        client:load 
        conferencia="valiente" 
        variant="dark"
        className="w-full py-4 text-base font-bold shadow-xl shadow-black/20"
      >
        Aparta tu lugar por $130
      </InscribeteButton>
    </div>
  </div>
</dialog>

<style>
  dialog[open] {
    animation: scale-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  dialog::backdrop {
    animation: fade-in 0.5s ease-out forwards;
  }
  @keyframes scale-up {
    0% { opacity: 0; transform: scale(0.9) translateY(15px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
  @keyframes fade-in {
    0% { opacity: 0; backdrop-filter: blur(0px); background: rgba(0, 0, 0, 0); }
    100% { opacity: 1; backdrop-filter: blur(8px); background: rgba(0, 0, 0, 0.5); }
  }
</style>
