---
// Panel Privado de Check-in (Ruta protegida para Staff)
import Layout from '../../layouts/Layout.astro';
import CheckinScanner from '../../components/CheckinScanner';

// Opcional: Podrías hacer un chequeo de contraseña aquí a nivel del servidor (SSR)
// const pass = Astro.url.searchParams.get('pass');
// if(pass !== 'M1Passw0rdSecreta') return Astro.redirect('/');
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Escaner de Boletos | Mujeres 2026</title>
  </head>
  <body class="bg-gray-900 text-white min-h-screen flex flex-col font-sans">
    <header class="w-full bg-black/50 p-4 border-b border-gray-800 text-center">
      <h1 class="text-2xl font-bold tracking-widest text-[#BFA077]">STAFF CHECK-IN</h1>
      <p class="text-xs text-gray-400">Escáner Oficial Mujeres 2026</p>
    </header>

    <main class="flex-1 overflow-y-auto p-4 flex flex-col items-center pt-8">
      {/* 
        Importante cargar con react (client:load o client:only) porque 
        html5-qrcode usa APIs exclusivas del navegador 
      */}
      <CheckinScanner client:only="react" />
    </main>
  </body>
</html>
